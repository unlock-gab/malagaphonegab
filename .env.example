# ──────────────────────────────────────────────────────────────────
#  MALAGA PHONE — متغيرات البيئة الإنتاجية
#  انسخ هذا الملف إلى .env وأملأ القيم الحقيقية
# ──────────────────────────────────────────────────────────────────

# قاعدة البيانات PostgreSQL
# عند الـ Docker Compose يكون هكذا:
#   DATABASE_URL=postgresql://malaga:PASSWORD@db:5432/malagaphone
# عند استخدام خدمة Dokploy Postgres منفصلة:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://malaga:CHANGE_ME@db:5432/malagaphone

# مفتاح سري للجلسات — ضع نصاً عشوائياً طويلاً (32+ حرف)
SESSION_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING

# الميناء الذي يستمع عليه السيرفر
PORT=5000

# بيئة التشغيل (لا تغيّره)
NODE_ENV=production

# ──────────────────────────────────────────────────────────────────
#  [اختياري] إذا تستخدم مع docker-compose.yml
# ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME
